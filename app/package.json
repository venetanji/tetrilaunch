  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@types/matter-js": "^0.19.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "^0.20.5"
  }
}
